# Copy this file to .env and fill in your values.
# Never commit .env to version control.

BOT_TOKEN=your_telegram_bot_token_here

# Docker-exposed ports (default: standard ports).
# Change if the defaults are already in use on your machine.
PG_PORT=5432
REDIS_PORT=6379

# Connection URLs (must match the ports above).
DATABASE_URL=postgres://moneytracker:moneytracker@localhost:5432/moneytracker?sslmode=disable
REDIS_URL=redis://localhost:6379

LOG_LEVEL=debug
MIGRATIONS_DIR=db/migrations

# Exchange rate cache TTL (default: 1 hour).
EXCHANGE_RATE_TTL=1h

# API server settings.
API_PORT=8080
ALLOWED_ORIGINS=https://money-tracker.hrxdev.cc

# Telegram Mini App URL (used by bot /start command).
MINI_APP_URL=https://money-tracker.hrxdev.cc

# Telegram user ID that has access to admin endpoints (0 = disabled).
ADMIN_USER_ID=0

# Local development: bypass Telegram auth (never enable in production).
# DEV_MODE=true
# DEV_LANG=en  # language code for the synthetic dev user (en, ru, uk, be, kk, uz, ...)

# Email for Let's Encrypt certificate registration.
CERTBOT_EMAIL=admin@hrxdev.cc
